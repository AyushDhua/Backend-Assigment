FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

SECRET_KEY=replace-with-a-strong-random-secret
JWT_SECRET_KEY=replace-with-a-strong-random-jwt-secret
JWT_ACCESS_TOKEN_HOURS=1
JWT_REFRESH_TOKEN_DAYS=7

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_app
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_app_test
SQLALCHEMY_ECHO=false

BCRYPT_LOG_ROUNDS=12

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
